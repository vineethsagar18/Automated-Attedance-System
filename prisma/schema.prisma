generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hashed
  role      Role     @default(FACULTY)
  createdAt DateTime @default(now())

  courses     Course[]
  attendances Attendance[]
  sessions    AttendanceSession[]
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
}

model Student {
  id           String   @id @default(cuid())
  name         String
  rollNo       String   @unique  // Unique Registration ID
  email        String?  @unique
  gender       String?
  contactNo    String?
  address      String?
  state        String?
  country      String?
  profileImage String?  // base64 JPEG data URL
  qrCode       String?  // base64 PNG
  createdAt    DateTime @default(now())

  enrollments Enrollment[]
  attendances Attendance[]
}

model Course {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  faculty   User     @relation(fields: [facultyId], references: [id])
  facultyId String
  createdAt DateTime @default(now())

  enrollments Enrollment[]
  attendances Attendance[]
  sessions    AttendanceSession[]
}

model Enrollment {
  id        String  @id @default(cuid())
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String

  @@unique([studentId, courseId])
}

model AttendanceSession {
  id          String   @id @default(cuid())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  token       String   @unique @default(cuid())
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  attendances Attendance[]

  @@index([token])
  @@index([courseId, isActive])
}

model Attendance {
  id           String           @id @default(cuid())
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId     String
  markedBy     User             @relation(fields: [markedById], references: [id])
  markedById   String
  session      AttendanceSession? @relation(fields: [sessionId], references: [id])
  sessionId    String?
  date         DateTime         @default(now())  // check-in timestamp
  checkOutTime DateTime?        // null = not yet checked out
  workMinutes  Int?             // calculated on checkout
  status       AttendanceStatus @default(PRESENT)
  method       MarkMethod       @default(MANUAL)

  @@index([studentId, courseId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum MarkMethod {
  QR_SCAN
  MANUAL
}
